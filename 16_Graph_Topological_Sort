import java.util.*;
public class Main {
    public static void main(String[] args) {
        int[][] prerequisites = {{1, 0}, {2, 0}, {3, 1}, {3, 2}};
        for (int i : orderCourses(4, prerequisites)) {
            System.out.println(i);
        }
    }

    // 1. can finish all courses
    public static boolean canFinish(int numCourses, int[][] prerequisites) {
        // create a map to denote our graph
        Map<Integer, Set<Integer>> map = new HashMap<>();
        // we need a degree array to denote # of each courses' prerequisites
        int[] degrees = new int[numCourses];
        // iterate prerequisites array
        for (int[] pre : prerequisites) {
            Set<Integer> set = map.getOrDefault(pre[1], new HashSet<>());
            set.add(pre[0]);
            map.put(pre[1], set);
            // update degrees
            degrees[pre[0]]++;
        }
        // implement BFS using a queue
        LinkedList<Integer> q = new LinkedList<>();
        // first, we add all courses which has degree value of zero to q
        for (int i = 0; i < numCourses; i++) {
            if (degrees[i] == 0) {
                q.offer(i);
            }
        }
        // initialize current available courses
        int count = q.size();
        // BFS
        while (!q.isEmpty()) {
            int curr = q.poll();
            if (!map.containsKey(curr)) {
                continue;
            }
            for (int next : map.get(curr)) {
                // decrement degree array
                degrees[next]--;
                // check if we can take next
                if (degrees[next] == 0) {
                    q.offer(next);
                    count++;
                }
            }
        }
        // finally, we check total available courses vs total courses
        return count == numCourses;
    }

    // 2. return the order of courses to take
    public static int[] orderCourses(int numCourses, int[][] prerequisites) {
        // create a map to denote our graph
        Map<Integer, Set<Integer>> map = new HashMap<>();
        // we need a degree array to denote # of each courses' prerequisites
        int[] degrees = new int[numCourses];
        // iterate prerequisites array
        for (int[] pre : prerequisites) {
            Set<Integer> set = map.getOrDefault(pre[1], new HashSet<>());
            set.add(pre[0]);
            map.put(pre[1], set);
            // update degrees
            degrees[pre[0]]++;
        }
        // implement BFS using a queue
        LinkedList<Integer> q = new LinkedList<>();
        int[] res = new int[numCourses];
        int idx = 0;
        // first, we add all courses which has degree value of zero to q
        for (int i = 0; i < numCourses; i++) {
            if (degrees[i] == 0) {
                q.offer(i);
            }
        }
        // initialize current available courses
        int count = q.size();
        // BFS
        while (!q.isEmpty()) {
            int curr = q.poll();
            res[idx++] = curr;
            if (!map.containsKey(curr)) {
                continue;
            }
            for (int next : map.get(curr)) {
                // decrement degree array
                degrees[next]--;
                // check if we can take next
                if (degrees[next] == 0) {
                    q.offer(next);
                    count++;
                }
            }
        }
        // finally, we check total available courses vs total courses
        return count == numCourses ? res : new int[0];
    }
}

