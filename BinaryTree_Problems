    // LCA
    public static TreeNode LCA(TreeNode root, TreeNode p, TreeNode q) {
        // we use post order traversal
        // 1. base case ?
        if (root == null) {
            return null; // could not find either p or q
        }
        if (root == p) {
            return root; // found p
        }
        if (root == q) {
            return root; // found q
        }
        TreeNode left = LCA(root.left, p, q); 
        TreeNode right = LCA(root.right, p, q); 
        // we visit root
        // if left and right both non-null -> we have found both p and q
        if (left != null && right != null) {
            return root; // LCA found!
        }
        if (left != null) { // left == q || left == p
            return left;
        }
        return right;
    }

    // right side view -> what about left side view? 
    public static List<Integer> rightSideView(TreeNode root) {
        List<Integer> res = new ArrayList<>();
        helper(res, 0, root);
        return res;
    }

    public static void helper(List<Integer> res, int currDepth, TreeNode root) {
        if (root == null) {
            return;
        }
        if (currDepth >= res.size()) {
            res.add(root.val);
        }
        helper(res, currDepth + 1, root.right);
        helper(res, currDepth + 1, root.left);
    }

    public static TreeNode sortedArrayToBST(int[] nums) {
        // corner cases
        // D & C
        return helper(0, nums.length - 1, nums);
    }

    public static TreeNode helper(int start, int end, int[] nums) {
        // 1. base case
        if (start > end) {
            return null;
        }
        if (start == end) {
            return new TreeNode(nums[start]);
        }
        // create our root node, we decide to use the middle idx to be root
        int mid = start + (end - start) / 2;
        TreeNode root = new TreeNode(nums[mid]);
        TreeNode left = helper(start, mid - 1, nums);
        TreeNode right = helper(mid + 1, end, nums);
        root.left = left;
        root.right = right;
        return root;
    }

    public static int maxDepth(TreeNode root) {
        // method 1: level order traversal, return the size of res
        // could we do it using post order? 
        if (root == null) {
            return 0;
        }
        int left = maxDepth(root.left); // left? 
        int right = maxDepth(root.right); // right? 
        int max = Math.max(left, right);
        return 1 + max;
    }

